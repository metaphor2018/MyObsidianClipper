{
  "manifest_version": 3,
  "name": "MyObsidianClipper",
  "version": "0.1.0",
  "description": "YouTubeの動画をGeminiで要約してObsidianに保存するChrome拡張",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MyObsidianClipper"
  },
  "options_page": "settings/settings.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/watch*",
        "https://*.youtube.com/watch*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  }
}
